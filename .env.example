# Порт сервера (по умолчанию 3001)
PORT=3001

# Режим разработки (development/production)
NODE_ENV=development

# Аутентификация (опционально)
# Если не задан — авторизация не требуется (локальный режим)
# ADMIN_PASSWORD=$2a$10$... (bcrypt hash пароля админа)
# Задайте открытый пароль — при первом запуске будет захеширован
ADMIN_PASSWORD=

# JWT Secret (если не задан, используется ADMIN_PASSWORD)
JWT_SECRET=

# Уровень логирования: error, warn, info, debug
LOG_LEVEL=info

# Настройки SMTP для отправки email (опционально)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# API ключ для REST API интеграций (опционально)
API_KEY=

# Лимиты генерации
# Максимальное количество строк за одну генерацию
MAX_ROWS_PER_GENERATION=10000
