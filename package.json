{
  "name": "certificate-generator",
  "version": "1.0.0",
  "description": "Генератор PDF-сертификатов из Excel и шаблона",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "cd client && npm run build",
    "start:server": "cd server && npm start",
    "standalone": "npm run build:client && npm run start:server"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@vercel/node": "^3.0.0",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "xlsx": "^0.18.5"
  }
}
